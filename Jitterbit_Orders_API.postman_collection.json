                    "key": "Authorization",
                    "value": "Bearer {{token}}"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"numeroPedido\": \"PEDIDO-001\",\n  \"valorTotal\": 350.75\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/order",
                  "host": ["{{baseUrl}}"],
                  "path": ["order"]
                }
              },
              "status": "Bad Request",
              "code": 400,
              "_postman_previewlanguage": "json",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"success\": false,\n  \"message\": \"Validation error\",\n  \"error\": \"dataCriacao is required\"\n}"
            },
            {
              "name": "Error - Duplicate Order ID",
              "originalRequest": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "Authorization",
                    "value": "Bearer {{token}}"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"numeroPedido\": \"PEDIDO-001\",\n  \"valorTotal\": 350.75,\n  \"dataCriacao\": \"2026-03-09T12:00:00Z\",\n  \"items\": [...]\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/order",
                  "host": ["{{baseUrl}}"],
                  "path": ["order"]
                }
              },
              "status": "Conflict",
              "code": 409,
              "_postman_previewlanguage": "json",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"success\": false,\n  \"message\": \"Order ID already exists\"\n}"
            }
          ]
        },
